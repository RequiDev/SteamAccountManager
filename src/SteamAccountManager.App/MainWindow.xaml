<ui:FluentWindow x:Class="SteamAccountManager.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:conv="clr-namespace:SteamAccountManager.App.Converters"
                 Title="Steam Account Manager"
                 Width="980" Height="640"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <conv:PathToImageConverter x:Key="PathToImage" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Steam Account Manager" />

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: group filter pane -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top" Text="Groups" FontSize="16" FontWeight="SemiBold" Margin="4,0,0,8" />
                <ListBox ItemsSource="{Binding GroupFilters}"
                         SelectedItem="{Binding SelectedGroupFilter, Mode=TwoWay}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Padding="6,4" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right: toolbar + cards -->
            <DockPanel Grid.Column="1">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button Content="Add account" Icon="{ui:SymbolIcon Add24}"
                               Command="{Binding AddAccountCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                    <ui:Button x:Name="SettingsButton" Content="Settings" Icon="{ui:SymbolIcon Settings24}"
                               Click="OnSettingsClick" />
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               Margin="16,0,0,0" TextWrapping="Wrap" Opacity="0.8" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredAccounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:CardControl Width="280" Margin="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="56" Height="56" CornerRadius="6"
                                                Margin="0,0,12,0" ClipToBounds="True">
                                            <Image Source="{Binding AvatarPath, Converter={StaticResource PathToImage}}"
                                                   Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Background="#2E7D32" CornerRadius="4" Padding="4,1" Margin="8,0,0,0"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="Active" Foreground="White" FontSize="10" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding AccountName}" Opacity="0.7" FontSize="12" />
                                            <TextBlock FontSize="11" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <!-- Default = Missing (no cached token). -->
                                                        <Setter Property="Text" Value="○ sign-in needed once" />
                                                        <Setter Property="Foreground" Value="#FFB74D" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TokenStatus}" Value="Ready">
                                                                <Setter Property="Text" Value="● ready — auto-login" />
                                                                <Setter Property="Foreground" Value="#66BB6A" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TokenStatus}" Value="Expired">
                                                                <Setter Property="Text" Value="○ expired — sign in once" />
                                                                <Setter Property="Foreground" Value="#FFB74D" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TokenStatus}" Value="ForeignMachine">
                                                                <Setter Property="Text" Value="○ from another PC — sign in once" />
                                                                <Setter Property="Foreground" Value="#FFB74D" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <ui:Button Content="Switch" Command="{Binding SwitchCommand}"
                                                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                                           Margin="0,0,6,0" />
                                                <ui:Button Content="Groups"
                                                           Tag="{Binding}"
                                                           Click="OnEditGroupsClick"
                                                           Margin="0,0,6,0" />
                                                <ui:Button Icon="{ui:SymbolIcon Edit24}" ToolTip="Edit label and notes"
                                                           Command="{Binding BeginEditCommand}" />
                                                <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18"
                                                                 Margin="6,0,0,0"
                                                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>

                                            <!-- Inline edit panel for custom label + notes (toggled by the pencil). -->
                                            <StackPanel Margin="0,8,0,0"
                                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <ui:TextBox PlaceholderText="Custom label"
                                                            Text="{Binding EditableLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Margin="0,0,0,6" />
                                                <ui:TextBox PlaceholderText="Notes"
                                                            Text="{Binding EditableNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            AcceptsReturn="True" TextWrapping="Wrap" MinLines="2"
                                                            Margin="0,0,0,6" />
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:Button Content="Save" Appearance="Primary"
                                                               Command="{Binding SaveLabelCommand}" Margin="0,0,6,0" />
                                                    <ui:Button Content="Cancel" Command="{Binding CancelEditCommand}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}" />
                                        </StackPanel>
                                    </Grid>
                                </ui:CardControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
