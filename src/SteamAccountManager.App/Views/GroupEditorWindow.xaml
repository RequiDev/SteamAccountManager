<ui:FluentWindow x:Class="SteamAccountManager.App.Views.GroupEditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Edit groups"
                 Width="520" Height="460"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="Edit groups" />

        <ScrollViewer Grid.Row="1" Margin="24,8">
            <ItemsControl ItemsSource="{Binding Memberships}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each group row: membership checkbox, inline rename TextBox + Rename, and Delete. -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsMember, Mode=TwoWay}"
                                      VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ui:TextBox Grid.Column="1" VerticalAlignment="Center"
                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Grid.Column="2" Content="Rename" Margin="6,0,0,0"
                                       Command="{Binding DataContext.RenameGroupCommand,
                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                       CommandParameter="{Binding}" />
                            <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon Delete24}" ToolTip="Delete group"
                                       Appearance="Danger" Margin="6,0,0,0"
                                       Command="{Binding DataContext.DeleteGroupCommand,
                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                       CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="24,8,24,16">
            <ui:TextBox PlaceholderText="New group name" Width="220"
                        Text="{Binding NewGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ui:Button Content="Add" Command="{Binding AddGroupCommand}" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
